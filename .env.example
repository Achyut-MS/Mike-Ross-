# ==============================================================================
# EvidenceChain Environment Variables
# ==============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ---- Django ----
SECRET_KEY=dev-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# ---- Database (PostgreSQL 15) ----
DATABASE_URL=postgresql://evidencechain_user:dev_password_change_in_prod@localhost:5432/evidencechain

# ---- OpenAI ----
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o

# ---- AWS S3 ----
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_S3_BUCKET_UPLOADS=evidencechain-uploads-dev
AWS_S3_REGION=ap-south-1
AWS_S3_ENDPOINT_URL=http://localhost:4566

# ---- Redis / Celery ----
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ---- ChromaDB ----
CHROMA_PERSIST_DIRECTORY=./backend/chroma_data
CHROMA_HOST=
CHROMA_PORT=8000

# ---- CORS ----
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
